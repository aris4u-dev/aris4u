# ARIS4U Secrets Configuration Template
# Copy this file to ~/.aris4u/secrets/ and populate with real values
# DO NOT commit real secrets to git — this is a template only

# Memory HMAC signing key
# Location: ~/.aris4u/secrets/memory_hmac.key
# Size: 32 bytes (256 bits)
# Generated by: engine.v16.memory_signer.MemorySigner()
# Auto-generated on first use if missing
MEMORY_HMAC_KEY_PATH="${HOME}/.aris4u/secrets/memory_hmac.key"

# Backup encryption key
# Location: ~/.aris4u/secrets/backup.key
# Size: 32 bytes (256 bits) in hex format
# Used with: openssl enc -aes-256-cbc -salt -pbkdf2
# Generate with: openssl rand -hex 32 > ~/.aris4u/secrets/backup.key
BACKUP_KEY_PATH="${HOME}/.aris4u/secrets/backup.key"

# Database path
CLAUDE_MEM_DB="${HOME}/.claude-mem/claude-mem.db"

# Backup configuration
BACKUP_DIR="${HOME}/Backups/aris4u-archives"
BACKUP_RETENTION_DAYS=28
BACKUP_MAX_COPIES=4

# TTL decay configuration
DECAY_AGE_DAYS=90
DECAY_MIN_RELEVANCE_COUNT=0
DECAY_ARCHIVE_TABLE="observations_archived"
DECAY_INTERVAL_DAYS=7

# Logging
LOG_DIR="/tmp/aris4u/logs"
LOG_LEVEL="INFO"
